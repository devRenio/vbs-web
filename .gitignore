.env
.env.*
!.env.example
*.pem
*-key.json
service-account*.json
credentials*.json
client_secret*.json

# ─── Local data / scratch (sheet exports — may contain PII, NEVER commit) ──
_scratch/
*.csv
*.xlsx
*.xls

# ─── Logs ───────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

