# ─────────────────────────────────────────────────────────────
# Copy this file to `.env` and fill in the values. NEVER commit `.env`.
# Only variables prefixed with VITE_ are exposed to the frontend bundle.
# ─────────────────────────────────────────────────────────────

# [REQUIRED] The deployed Google Apps Script Web App URL (ends with /exec).
# Deploy the GAS project as "Web app", execute as you, access = "Anyone".
# The GAS code is the only thing that touches the master sheet + PII; it must
# return ONLY { id, row, no, name, gender, church, className, attendance }.
VITE_GAS_API_URL=https://script.google.com/macros/s/XXXXXXXXXXXXXXXXXXXXXXXX/exec

# [REQUIRED for production] Shared access code — teachers enter this to open the app,
# and every GAS API call includes it. Must ALSO be set in Apps Script:
#   Project Settings ⚙ → Script properties → APP_TOKEN = (same value)
# Use a long random string (e.g. Za7NY9lqmg5QoI8UcRnuAGE4). Do NOT use guessable words.
# Teachers open: https://<user>.github.io/vbs-web/?key=<this value>
# (Share that full link privately — not the bare /vbs-web/ URL.)
VITE_APP_TOKEN=vbs-change-me-to-a-long-random-string

# [OPTIONAL] Hot-standby endpoints for automatic failover.
# If the primary URL above keeps failing (throttled, quota-capped, bad deploy),
# the client transparently retries against these, in order. Comma/space separated.
# Tip: deploy the SAME Code.gs as a second "Web app" deployment and paste its /exec here.
# VITE_GAS_API_FALLBACK_URLS=https://script.google.com/macros/s/YYYYYYYY/exec

# [OPTIONAL] Resilience tuning (defaults are sensible; override only if needed).
# VITE_GAS_RETRIES=3              # retry attempts per endpoint for transient errors
# VITE_GAS_TIMEOUT_MS=15000       # per-attempt request timeout (ms)
# VITE_GAS_WRITE_MIN_GAP_MS=350   # min gap between serialized attendance writes (ms)
